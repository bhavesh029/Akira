# NestJS Application Port
PORT=3000

# Database Configuration (Supabase PostgreSQL)
# Example: postgresql://postgres.your_project_ref:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=your-supabase-database-url

# JWT Authentication Config
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=1d

# Supabase Storage (for document file uploads)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=Statements

# Google Gemini API (for AI-powered document extraction)
# Get a key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
